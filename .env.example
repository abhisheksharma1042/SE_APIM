# =============================================================================
# .env.example — Copy to .env and fill in your values.
# .env is gitignored — NEVER commit secrets to the repository.
# =============================================================================

# ── Azure Subscription (workforce tenant) ────────────────────────────────────
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000    # Your workforce tenant

# ── Service Principal for CI/CD and scripts ───────────────────────────────────
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-here              # Or use OIDC (see doc 05)

# ── APIM Instance ─────────────────────────────────────────────────────────────
APIM_SERVICE_NAME=contoso-apim
APIM_RESOURCE_GROUP=rg-apim-prod

# ── Entra External ID (External Tenant) ──────────────────────────────────────
EXTERNAL_TENANT_ID=00000000-0000-0000-0000-000000000000
EXTERNAL_TENANT_DOMAIN=contosocustomers                  # e.g. contosocustomers.onmicrosoft.com

# ── App Registrations (populated by setup-external-tenant.sh) ─────────────────
API_APP_ID=00000000-0000-0000-0000-000000000000          # The API / resource app
CLIENT_APP_ID=00000000-0000-0000-0000-000000000000       # The SPA client app
DAEMON_APP_ID=00000000-0000-0000-0000-000000000000       # The daemon/service client
DAEMON_CLIENT_SECRET=your-daemon-secret-here

# ── App Role IDs (populated by setup-external-tenant.sh) ──────────────────────
READER_ROLE_ID=00000000-0000-0000-0000-000000000000
WRITER_ROLE_ID=00000000-0000-0000-0000-000000000000
ADMIN_ROLE_ID=00000000-0000-0000-0000-000000000000

# ── For existing Azure AD B2C tenants (optional) ──────────────────────────────
# B2C_TENANT=contoso
# B2C_USER_FLOW=B2C_1_susi
APP_DISPLAY_NAME=Contoso API
